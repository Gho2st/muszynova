// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Restaurant {
  id                         String   @id @default(cuid())
  name                       String
  address                    String
  phone                      String?
  email                      String?
  openingTime                String?
  closingTime                String?
  defaultReservationDuration Int      @default(90)
  slotDuration               Int      @default(30)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  tables       Table[]
  reservations Reservation[]

  @@map("restaurants")
}

model Table {
  id          String      @id @default(cuid())
  number      Int
  capacity    Int
  minCapacity Int         @default(1)
  status      TableStatus @default(AVAILABLE)
  location    String?
  isActive    Boolean     @default(true)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, number])
  @@index([restaurantId, status])
  @@map("tables")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]

  @@index([email])
  @@map("customers")
}

model Reservation {
  id                 String            @id @default(cuid())
  startTime          DateTime
  endTime            DateTime
  durationMinutes    Int               @default(90)
  partySize          Int
  status             ReservationStatus @default(PENDING)
  notes              String?
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id])

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId, startTime])
  @@index([tableId, startTime, endTime])
  @@index([customerId])
  @@index([status])
  @@map("reservations")
}

model Post {
  id              Int               @id @default(autoincrement())
  coverImage      String?
  status          String            @default("draft")
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  // CTA - URLs (wspólne dla wszystkich języków)
  ctaPrimaryUrl   String?
  ctaSecondaryUrl String?
  translations    PostTranslation[]
}

model PostTranslation {
  id      Int     @id @default(autoincrement())
  locale  String
  slug    String
  title   String
  excerpt String?
  content String

  ctaTitle          String?
  ctaDescription    String?
  ctaPrimaryLabel   String?
  ctaSecondaryLabel String?

  // Hash źródła PL z którego powstało to tłumaczenie
  // (oddzielnie per pole, żeby tłumaczyć selektywnie)
  sourceHashTitle   String?
  sourceHashExcerpt String?
  sourceHashContent String?
  sourceHashCta     String? // wspólny dla 4 pól CTA

  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, locale])
  @@unique([locale, slug])
  @@index([postId])
  @@map("post_translations")
}
