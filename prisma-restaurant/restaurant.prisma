generator client {
    provider = "prisma-client"
    output   = "../generated/restaurant"
}

datasource db {
    provider = "postgresql"
}

enum TableStatus {
    AVAILABLE
    OCCUPIED
    RESERVED
    MAINTENANCE
}

enum ReservationStatus {
    PENDING
    CONFIRMED
    CANCELLED
    COMPLETED
    NO_SHOW
}

model Restaurant {
    id                         String   @id @default(cuid())
    name                       String
    address                    String
    phone                      String?
    email                      String?
    openingTime                String?
    closingTime                String?
    defaultReservationDuration Int      @default(90)
    slotDuration               Int      @default(30)
    createdAt                  DateTime @default(now())
    updatedAt                  DateTime @updatedAt

    tables       Table[]
    reservations Reservation[]

    @@map("restaurants")
}

model Table {
    id          String      @id @default(cuid())
    number      Int
    capacity    Int
    minCapacity Int         @default(1)
    status      TableStatus @default(AVAILABLE)
    location    String?
    isActive    Boolean     @default(true)

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

    reservations Reservation[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([restaurantId, number])
    @@index([restaurantId, status])
    @@map("tables")
}

model Customer {
    id        String   @id @default(cuid())
    name      String
    email     String   @unique
    phone     String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    reservations Reservation[]

    @@index([email])
    @@map("customers")
}

model Reservation {
    id                 String            @id @default(cuid())
    startTime          DateTime
    endTime            DateTime
    durationMinutes    Int               @default(90)
    partySize          Int
    status             ReservationStatus @default(PENDING)
    notes              String?
    confirmedAt        DateTime?
    cancelledAt        DateTime?
    cancellationReason String?

    customerId String
    customer   Customer @relation(fields: [customerId], references: [id])

    tableId String?
    table   Table?  @relation(fields: [tableId], references: [id])

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([restaurantId, startTime])
    @@index([tableId, startTime, endTime])
    @@index([customerId])
    @@index([status])
    @@map("reservations")
}
